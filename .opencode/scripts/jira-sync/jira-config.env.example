# JIRA Configuration Template
# Copy this file to jira-config.env and fill in your values
# DO NOT commit jira-config.env to version control

# JIRA Instance
JIRA_DOMAIN="your-company.atlassian.net"

# Authentication - Generate API token from https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_EMAIL="your-email@company.com"
JIRA_API_TOKEN="your-api-token-here"

# Project Key - The JIRA project key (e.g., "PROJ", "SPRINT")
JIRA_PROJECT_KEY="PROJECT_KEY"

# OAuth (alternative to API token)
# JIRA_CLIENT_ID="your-oauth-client-id"
# JIRA_CLIENT_SECRET="your-oauth-client-secret"

# Field Mappings - Customize based on your JIRA instance
# JIRA_EPIC_FIELD="customfield_10001"        # Field ID for Epic Name
# JIRA_STORY_POINTS_FIELD="customfield_10002" # Field ID for Story Points
# JIRA_SPRINT_FIELD="customfield_10003"       # Field ID for Sprint

# Optional: Proxy settings
# JIRA_HTTP_PROXY=""
# JIRA_HTTPS_PROXY=""

# Behavior flags
JIRA_VERIFY_SSL=true
JIRA_TIMEOUT=30